    if child.Name == "NPCs" then task.wait(1); refreshDropdownContents() end
end))

-- Click to Teleport Connection
table.insert(Connections, Mouse.Button1Down:Connect(function()
    if Flags.ClickTeleport then
        local target = Mouse.Target
        if target and target.Parent then
            local humanoid = target.Parent:FindFirstChildWhichIsA("Humanoid")
            local targetRoot = target.Parent:FindFirstChild("HumanoidRootPart")
            if humanoid and targetRoot then
                TeleportTo(targetRoot.CFrame, 0)
            end
        end
    end
end))


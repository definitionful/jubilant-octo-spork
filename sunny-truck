Tabs.Movement:AddButton({
    Title = "Teleport To Friendly",
    Callback = function()
        if selectedFriendly == "Select Friendly" or not selectedFriendly then return end
        local friendlyFolder = Workspace:FindFirstChild("NPCs") and Workspace.NPCs:FindFirstChild("Friendly")
        local npc = friendlyFolder and friendlyFolder:FindFirstChild(selectedFriendly)
        local npcRoot = npc and (npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChildWhichIsA("BasePart"))
        
        if npcRoot then
            -- Find position 1 stud in front of NPC (Assuming Roblox default -Z is Forward)
            local frontCFrame = npcRoot.CFrame * CFrame.new(0, 0, -1)
            local playerStandPos = frontCFrame.Position
            local npcLookPos = npcRoot.Position
            
            -- Keep Y coordinates level so character doesn't pitch downwards or upwards
            local targetCFrame = CFrame.lookAt(playerStandPos, Vector3.new(npcLookPos.X, playerStandPos.Y, npcLookPos.Z))
            TeleportTo(targetCFrame, 0)
        else
            Fluent:Notify({Title = "Error", Content = "Friendly NPC not found!", Duration = 3})
        end
    end
})


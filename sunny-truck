local function DisconnectAll()
    for _, conn in ipairs(Connections) do
        if conn.Connected then conn:Disconnect() end
    end
    table.clear(Connections)
end

local function GetRootPart()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

-- Updated TeleportTo function supporting Tween and Instant methods
local function TeleportTo(targetCFrame, yOffset)
    local rootPart = GetRootPart()
    if not rootPart then return false end
    
    yOffset = yOffset or 3
    local finalCFrame = targetCFrame + Vector3.new(0, yOffset, 0)
    
    if Flags.TeleportMethod == "Tween" then
        local tweenInfo = TweenInfo.new(Flags.TweenSpeed, Enum.EasingStyle.Linear)
        local tween = TweenService:Create(rootPart, tweenInfo, {CFrame = finalCFrame})
        tween:Play()
        tween.Completed:Wait() -- Wait for tween to finish
    else
        rootPart.CFrame = finalCFrame
        task.wait(0.15)
    end
    
    -- Resetting velocities preventing rubberbanding
    rootPart.AssemblyLinearVelocity = Vector3.zero
    rootPart.AssemblyAngularVelocity = Vector3.zero
    return true
end

local function getTargets()
    local targets = {"Select Target"}
    if targetMode == "NPC" then
        local hostileFolder = Workspace:FindFirstChild("NPCs") and Workspace.NPCs:FindFirstChild("Hostile")
        if hostileFolder then
            local nameCounts = {}
            for _, npc in ipairs(hostileFolder:GetChildren()) do
                nameCounts[npc.Name] = (nameCounts[npc.Name] or 0) + 1
                local displayName = npc.Name .. " #" .. nameCounts[npc.Name]
                table.insert(targets, displayName)
            end
        end
    elseif targetMode == "Player" then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                table.insert(targets, player.Name)
            end
        end
    end
    return targets
end

local function getFriendlyNPCs()
    local targets = {"Select Friendly"}
    local friendlyFolder = Workspace:FindFirstChild("NPCs") and Workspace.NPCs:FindFirstChild("Friendly")
    if friendlyFolder then
        for _, npc in ipairs(friendlyFolder:GetChildren()) do
            table.insert(targets, npc.Name)
        end
    end
    return targets
end

local function getAliveNPC(selectedStr)
    if not selectedStr or selectedStr == "Select Target" then return nil end
    local name, targetIndex = selectedStr:match("^(.-) #(%d+)$")
    targetIndex = tonumber(targetIndex)
    if not name then name = selectedStr end
    
    local hostileFolder = Workspace:FindFirstChild("NPCs") and Workspace.NPCs:FindFirstChild("Hostile")
    if not hostileFolder then return nil end
    
    local count = 0
    for _, child in ipairs(hostileFolder:GetChildren()) do
        if child.Name == name then
            count = count + 1
            if not targetIndex or count == targetIndex then
                local humanoid = child:FindFirstChildWhichIsA("Humanoid")
                local rootPart = child:FindFirstChild("HumanoidRootPart") or child:FindFirstChildWhichIsA("BasePart")
                if humanoid and humanoid.Health > 0 and rootPart then
                    return child
                end
            end
        end
    end
    return nil
end

local function refreshDropdownContents()
    if TargetDropdown then TargetDropdown:SetValues(getTargets()) end
    if FriendlyDropdown then FriendlyDropdown:SetValues(getFriendlyNPCs()) end
end

table.insert(Connections, Players.PlayerAdded:Connect(refreshDropdownContents))

AutoFarmToggle = Tabs.Combat:AddToggle("AutoFarmToggle", {
    Title = "Auto Farm",
    Default = false,
    Callback = function(state)
        Flags.AutoFarm = state
        
        if Flags.AutoFarm then
            if selectedTarget == "Select Target" or selectedTarget == nil then
                Fluent:Notify({ Title = "Auto Farm Error", Content = "Please select a Target first!", Duration = 5 })
                AutoFarmToggle:SetValue(false)
                return
            end

            local character = LocalPlayer.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                lastPosition = rootPart.CFrame
            end

            farmHeartbeat = RunService.Heartbeat:Connect(function()
                if not Flags.AutoFarm or not ScriptRunning then return end
                local char = LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if not root then return end
                
                local targetRoot = nil
                local targetHumanoid = nil
                
                if targetMode == "Player" then
                    local viaPlayer = Players:FindFirstChild(selectedTarget)
                    if viaPlayer and viaPlayer.Character then
                        targetHumanoid = viaPlayer.Character:FindFirstChildWhichIsA("Humanoid")
                        targetRoot = viaPlayer.Character:FindFirstChild("HumanoidRootPart")
                    end
                elseif targetMode == "NPC" then
                    local hostileFolder = Workspace:FindFirstChild("NPCs") and Workspace.NPCs:FindFirstChild("Hostile")
                    local baseName = selectedTarget:match("^(.-) #(%d+)$") or selectedTarget
                    
                    if currentFarmNPC and currentFarmNPC.Parent == hostileFolder and currentFarmNPC.Name == baseName then
                        local hum = currentFarmNPC:FindFirstChildWhichIsA("Humanoid")
                        if not hum or hum.Health <= 0 then currentFarmNPC = nil end
                    else
                        currentFarmNPC = nil 
                    end
                    
                    if not currentFarmNPC then currentFarmNPC = getAliveNPC(selectedTarget) end
                    
                    if currentFarmNPC then
                        targetHumanoid = currentFarmNPC:FindFirstChildWhichIsA("Humanoid")
                        targetRoot = currentFarmNPC:FindFirstChild("HumanoidRootPart") or currentFarmNPC:FindFirstChildWhichIsA("BasePart")
                    end
                end
                
                if targetRoot and targetHumanoid and targetHumanoid.Health > 0 then
                    -- Direct CFrame setting during loops to prevent bouncing, tweening is only for singular travels
                    local behindCFrame = targetRoot.CFrame * CFrame.new(0, 0, farmDistance)
                    root.CFrame = CFrame.lookAt(behindCFrame.Position, targetRoot.Position)
                    root.AssemblyLinearVelocity = Vector3.zero
                    root.AssemblyAngularVelocity = Vector3.zero
                end
            end)
            table.insert(Connections, farmHeartbeat)
            
        else
            if farmHeartbeat then
                farmHeartbeat:Disconnect()
                farmHeartbeat = nil
            end
            
            if lastPosition and ScriptRunning then
                if Flags.ReturnToLastPos then
                    local character = LocalPlayer.Character
                    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
                    if rootPart then
                        rootPart.CFrame = lastPosition
                        rootPart.AssemblyLinearVelocity = Vector3.zero
                        rootPart.AssemblyAngularVelocity = Vector3.zero
                    end
                end
                lastPosition = nil
            end
        end
    end
})


if getgenv().HitboxHubUnload then
    pcall(getgenv().HitboxHubUnload)
end

local activeConnections = {}
local activeDrawings = {}

getgenv().HitboxHubUnload = function()
    for _, conn in ipairs(activeConnections) do
        if conn.Disconnect then conn:Disconnect() end
    end
    for _, drawing in ipairs(activeDrawings) do
        if drawing.Remove then pcall(drawing.Remove, drawing) end
    end
    table.clear(activeConnections)
    table.clear(activeDrawings)
end

local safeDrawing = function(type)
    local success, obj = pcall(Drawing.new, type)
    if success and obj then
        table.insert(activeDrawings, obj)
        return obj
    end
    return nil
end


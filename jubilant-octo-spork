local bodyParts = {"Head", "HumanoidRootPart"}
local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Exclude
raycastParams.IgnoreWater = true

local function applyHeadModifiers(player, head)
    if not isHeadModifierActive or player == LocalPlayer then return end
    if table.find(ignoredTeamsList, player.Team and player.Team.Name or "") then return end

    head.Massless = true
    head.CanCollide = false
    head.Size = Vector3.new(targetHeadSize, targetHeadSize, targetHeadSize)
    head.Transparency = targetTransparency
    
    local face = head:FindFirstChildOfClass("Decal")
    if face then face.Transparency = targetTransparency end
end

local function UpdateAllHeads()
    for _, player in Players:GetPlayers() do
        if player ~= LocalPlayer and player.Character then
            local head = player.Character:FindFirstChild("Head")
            if head and head:IsA("BasePart") then
                if isHeadModifierActive then
                    applyHeadModifiers(player, head)
                elseif defaultHeadData[player] then
                    head.Massless = false
                    head.CanCollide = true
                    head.Size = defaultHeadData[player].Size
                    head.Transparency = defaultHeadData[player].Transparency
                    
                    local face = head:FindFirstChildOfClass("Decal")
                    if face then face.Transparency = defaultHeadData[player].Transparency end
                end
            end
        end
    end
end

local function cacheHead(character, player)
    local head = character:WaitForChild("Head", 5)
    if head and head:IsA("BasePart") then
        defaultHeadData[player] = {
            Size = head.Size,
            Transparency = head.Transparency
        }
        applyHeadModifiers(player, head)
    end
end

local function createESP(player)
    local box = safeDrawing("Square")
    local name = safeDrawing("Text")
    
    if box and name then
        ESP_DATA[player] = { Box = box, Name = name }

        box.Visible = false
        box.Thickness = 1.5
        box.Filled = false

        name.Visible = false
        name.Text = player.Name
        name.Size = 16
        name.Center = true
        name.Outline = true
        name.Color = Color3.fromRGB(255, 255, 255)
    end
end

local function setupPlayer(player)
    if player.Character then task.spawn(cacheHead, player.Character, player) end
    table.insert(activeConnections, player.CharacterAdded:Connect(function(char) task.spawn(cacheHead, char, player) end))
    if player ~= LocalPlayer then createESP(player) end
end

for _, player in Players:GetPlayers() do
    setupPlayer(player)
end

table.insert(activeConnections, Players.PlayerAdded:Connect(setupPlayer))

table.insert(activeConnections, Players.PlayerRemoving:Connect(function(player)
    defaultHeadData[player] = nil
    if ESP_DATA[player] then
        if ESP_DATA[player].Box then pcall(ESP_DATA[player].Box.Remove, ESP_DATA[player].Box) end
        if ESP_DATA[player].Name then pcall(ESP_DATA[player].Name.Remove, ESP_DATA[player].Name) end
        ESP_DATA[player] = nil
    end
end))

local function isAlive(player)
    local char = player.Character
    local hum = char and char:FindFirstChild("Humanoid")
    return hum and hum.Health > 0
end

local function hasForceField(character)
    return character:FindFirstChildOfClass("ForceField") ~= nil
end

local function isVisible(targetCharacter, targetPos, cameraOrigin)
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    local direction = targetPos - cameraOrigin
    local result = workspace:Raycast(cameraOrigin, direction, raycastParams)
    return not result or result.Instance:IsDescendantOf(targetCharacter)
end

local function getTarget()
    local originLocation = isOtsMode and (Camera.ViewportSize / 2) or UserInputService:GetMouseLocation()
    local cameraOrigin = Camera.CFrame.Position
    local shortestDistanceSq = FOV_RADIUS * FOV_RADIUS 
    local bestPlayer = nil
    local bestPart = nil

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or not isAlive(player) then continue end
        if table.find(ignoredTeamsList, player.Team and player.Team.Name or "") then continue end
        
        local character = player.Character
        if USE_FORCEFIELD_CHECK and hasForceField(character) then continue end
        
        for _, partName in ipairs(bodyParts) do
            local part = character:FindFirstChild(partName)
            if part then
                local checkPosition = part.Position
                if USE_PREDICTION then
                    checkPosition += (part.AssemblyLinearVelocity * PREDICTION_FACTOR)
                end

                local screenPos, onScreen = Camera:WorldToViewportPoint(checkPosition)
                if onScreen then
                    local distSq = (screenPos.X - originLocation.X)^2 + (screenPos.Y - originLocation.Y)^2

                    if distSq < shortestDistanceSq then
                        if not USE_VISIBLE_CHECK or isVisible(character, checkPosition, cameraOrigin) then
                            shortestDistanceSq = distSq
                            bestPlayer = player
                            bestPart = part
                        end
                    end
                end
            end
        end
    end

    return bestPlayer, bestPart
end

table.insert(activeConnections, RunService.RenderStepped:Connect(function()
    if not Camera then return end
    local camPos = Camera.CFrame.Position
    local screenCenter = Camera.ViewportSize / 2
    local mouseLocation = UserInputService:GetMouseLocation()
    
    for player, objects in ESP_DATA do
        local isVisibleNode = false
        
        if espSettings.Master then
            local character = player.Character
            if character then
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                local humanoid = character:FindFirstChild("Humanoid")

                if rootPart and humanoid and humanoid.Health > 0 then
                    local screenPoint, onScreen = Camera:WorldToViewportPoint(rootPart.Position)

                    if onScreen then
                        isVisibleNode = true
                        local distance = (camPos - rootPart.Position).Magnitude
                        local height = math.clamp(3000 / distance, 10, 500)
                        local width = height / 1.5

                        local renderColor = (espSettings.TeamColor and player.Team) and player.TeamColor.Color or espSettings.BoxColor

                        if objects.Box then
                            objects.Box.Size = Vector2.new(width, height)
                            objects.Box.Position = Vector2.new(screenPoint.X - width / 2, screenPoint.Y - height / 2)
                            objects.Box.Color = renderColor
                            objects.Box.Visible = espSettings.Box
                        end

                        if objects.Name then
                            objects.Name.Position = Vector2.new(screenPoint.X, screenPoint.Y - (height / 2) - 18)
                            objects.Name.Color = renderColor
                            objects.Name.Visible = espSettings.Name
                        end
                    end
                end
            end
        end
        
        if not isVisibleNode then
            if objects.Box then objects.Box.Visible = false end
            if objects.Name then objects.Name.Visible = false end
        end
    end

    if FOVCircle then
        FOVCircle.Position = isOtsMode and screenCenter or mouseLocation
    end

    if not isAimEnabled then return end

    local isHoldingRightClick = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    if isOtsMode and not isHoldingRightClick then return end
    if not isOtsMode and isHoldingRightClick then return end

    local target, targetPart = getTarget()
    
    if target and targetPart and isAlive(target) then
        local targetPosition = targetPart.Position
        if USE_PREDICTION then
            targetPosition += (targetPart.AssemblyLinearVelocity * PREDICTION_FACTOR)
        end

        local partPos = Camera:WorldToViewportPoint(targetPosition)
        local activeOrigin = isOtsMode and screenCenter or mouseLocation
        
        local deltaX = (partPos.X - activeOrigin.X) * SMOOTHING
        local deltaY = (partPos.Y - activeOrigin.Y) * SMOOTHING
        
        if type(mousemoverel) == "function" then
            pcall(mousemoverel, deltaX, deltaY)
        end
    end
end))

